# Admin UI credentials (HTTP Basic Auth)
# REQUIRED: the app refuses to start if ADMIN_PASSWORD is unset or "changeme".
ADMIN_USER=admin
ADMIN_PASSWORD=

# SQLite data path (default works with the Docker volume)
DATABASE_URL=sqlite:////data/notify-proxy.db

# Log level: DEBUG, INFO, WARNING
LOG_LEVEL=INFO

# --- Optional: Coolify integration ---
# COOLIFY_BASE_URL=https://coolify.example.com
# COOLIFY_TOKEN=                 # Coolify API token (for "Sync from Coolify")
# COOLIFY_INCOMING_TOKEN=        # shared token Coolify must send on webhooks

# --- Optional: dedicated Telegram verification bot ---
# VERIFICATION_BOT_TOKEN=        # also settable via the Settings UI

# --- Optional: deploy image override (docker-compose) ---
# NOTIFY_PROXY_IMAGE=ghcr.io/your-org/notify-proxy:main
