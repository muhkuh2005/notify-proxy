# --- Admin UI auth: Basic OR OAuth ---
# If OAUTH_ENABLED_PROVIDERS is set, OAuth login is used and Basic is disabled.
# Otherwise HTTP Basic Auth applies (and ADMIN_PASSWORD is required).
ADMIN_USER=admin
ADMIN_PASSWORD=

# --- Optional: OAuth login (replaces Basic Auth when set) ---
# Comma-separated subset of: github,microsoft
# OAUTH_ENABLED_PROVIDERS=github,microsoft
# SESSION_SECRET=                # REQUIRED with OAuth — long random string (signs the session cookie)
# BASE_URL=https://notify.example.com   # public URL; OAuth redirect = {BASE_URL}/auth/{provider}/callback
# OAUTH_ADMIN_EMAILS=you@example.com    # these emails become admin+approved on login;
#                                       # if empty, the very first user to log in becomes admin.
# Provider apps (redirect URI: {BASE_URL}/auth/<provider>/callback):
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT=common        # or your tenant id / "organizations"

# --- Optional: encrypt secret columns at rest (bot tokens, webhook URLs, SMTP pw) ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Without it, secrets are stored as plaintext (backward compatible). Keep it stable!
# TOKEN_ENCRYPTION_KEY=

# SQLite data path (default works with the Docker volume)
DATABASE_URL=sqlite:////data/notify-proxy.db

# Log level: DEBUG, INFO, WARNING
LOG_LEVEL=INFO

# --- Optional: rate limiting (in-memory, per-IP) ---
# RATELIMIT_ENABLED=true
# RATELIMIT_LOGIN_PER_MIN=10      # /login + /auth/*
# RATELIMIT_WEBHOOK_PER_MIN=120   # /webhook/*

# --- Optional: Coolify integration ---
# COOLIFY_BASE_URL=https://coolify.example.com
# COOLIFY_TOKEN=                 # Coolify API token (for "Sync from Coolify")
# COOLIFY_INCOMING_TOKEN=        # shared token Coolify must send on webhooks

# --- Optional: dedicated Telegram verification bot ---
# VERIFICATION_BOT_TOKEN=        # also settable via the Settings UI

# --- Optional: deploy image override (docker-compose) ---
# NOTIFY_PROXY_IMAGE=ghcr.io/your-org/notify-proxy:main
